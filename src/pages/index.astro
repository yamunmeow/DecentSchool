---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import RainbowCard from '../components/RainbowCard.astro';
import NewsTicker from '../components/NewsTicker.astro';

const recentNews = [
  { text: "🚀 New AI in Education Policy Released", link: "/news/ai-policy" },
  { text: "🎨 Student Art Competition Winners Announced", link: "/news/art-winners" },
  { text: "📱 DecentralSchool App Launches Beta", link: "/news/app-beta" },
  { text: "🌈 Rainbow Coding Workshop This Saturday", link: "/news/coding-workshop" },
];
---

<Layout title="Home - DecentralSchool">
  <Navbar />
  
  <main class="container">
    <section class="hero">
      <h1 class="rainbow-text hero-title">Welcome to DecentralSchool</h1>
      <p class="hero-subtitle">Where education meets creativity and technology 🌈</p>
      <div class="hero-buttons">
        <a href="/code-lab" class="rainbow-button">Start Coding</a>
        <a href="/texts" class="rainbow-button">Explore Texts</a>
      </div>
    </section>

    <NewsTicker news={recentNews} />

    <section class="featured-section">
      <h2 class="section-title">📚 Featured Content</h2>
      <div class="grid">
        <RainbowCard
          title="Introduction to Blockchain"
          description="Learn the basics of blockchain technology in a fun, colorful way"
          link="/texts/blockchain-intro"
          emoji="🔗"
          date="2 hours ago"
        />
        <RainbowCard
          title="Coding Memes of the Week"
          description="The funniest programming memes to brighten your day"
          link="/memes/weekly"
          emoji="😂"
          date="5 hours ago"
        />
        <RainbowCard
          title="Educational Policy Update"
          description="Latest changes in decentralized education systems"
          link="/news/policy-update"
          emoji="📰"
          date="1 day ago"
        />
      </div>
    </section>

    <section class="categories">
      <h2 class="section-title">🎨 Explore Categories</h2>
      <div class="category-grid">
        <a href="/texts" class="category-card" style="background: linear-gradient(135deg, #ff6b6b, #ffb347)">
          <span class="category-emoji">📝</span>
          <span class="category-name">Texts & Articles</span>
        </a>
        <a href="/memes" class="category-card" style="background: linear-gradient(135deg, #ffb347, #ffd93b)">
          <span class="category-emoji">😂</span>
          <span class="category-name">Memes</span>
        </a>
        <a href="/illustrations" class="category-card" style="background: linear-gradient(135deg, #ffd93b, #6bcf7f)">
          <span class="category-emoji">🎨</span>
          <span class="category-name">Illustrations</span>
        </a>
        <a href="/code-lab" class="category-card" style="background: linear-gradient(135deg, #6bcf7f, #4d9eff)">
          <span class="category-emoji">💻</span>
          <span class="category-name">Code Lab</span>
        </a>
        <a href="/news" class="category-card" style="background: linear-gradient(135deg, #4d9eff, #9d7eff)">
          <span class="category-emoji">📰</span>
          <span class="category-name">News</span>
        </a>
        <a href="/blog" class="category-card" style="background: linear-gradient(135deg, #9d7eff, #ff85b3)">
          <span class="category-emoji">📱</span>
          <span class="category-name">Blog</span>
        </a>
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-content card">
        <h2>🎮 Want to contribute?</h2>
        <p>Add your own content, code, or ideas to DecentralSchool!</p>
        <a href="https://github.com/yourusername/DecentralSchool" class="rainbow-button">GitHub Repository</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🌈 Made with love for decentralized education</p>
      <p>© 2024 DecentralSchool</p>
    </div>
  </footer>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 60px 0;
  }

  .hero-title {
    font-size: 3.5rem;
    margin-bottom: 20px;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: var(--text-secondary);
    margin-bottom: 30px;
  }

  .hero-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
  }

  .section-title {
    font-size: 2.2rem;
    margin: 40px 0 20px;
    text-align: center;
    background: linear-gradient(90deg, 
      var(--rainbow-1), 
      var(--rainbow-2), 
      var(--rainbow-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
    margin: 30px 0;
  }

  .category-card {
    padding: 30px 20px;
    border-radius: 15px;
    text-align: center;
    text-decoration: none;
    color: white;
    font-weight: bold;
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .category-card:hover {
    transform: scale(1.05);
  }

  .category-emoji {
    font-size: 3rem;
  }

  .cta-section {
    margin: 60px 0;
  }

  .cta-content {
    text-align: center;
    padding: 50px;
  }

  .cta-content h2 {
    font-size: 2rem;
    margin-bottom: 15px;
  }

  .cta-content p {
    margin-bottom: 25px;
    font-size: 1.1rem;
  }

  .footer {
    background: rgba(0, 0, 0, 0.1);
    padding: 30px 0;
    margin-top: 60px;
    text-align: center;
    color: var(--text-secondary);
  }
</style>